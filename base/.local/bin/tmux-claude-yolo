#!/usr/bin/env bash
# tmux-claude-yolo — launch claude in YOLO mode, optionally picking a dir first
#
# Usage:
#   tmux-claude-yolo            # current dir (no picker)
#   tmux-claude-yolo --pick     # fzf-pick from zoxide frecent dirs

set -e

if [[ "${1:-}" == "--pick" ]]; then
  selected=$(zoxide query -l | fzf --prompt="claude in: " --height=100%) || exit 0
  [[ -z "$selected" ]] && exit 0
  cd "$selected"
fi

exec claude --dangerously-skip-permissions
