#!/usr/bin/env bash

# tmux-window-switcher - Switch to or create a tmux window with a given name and command
# Usage: tmux-window-switcher <window-name> <command> [working-directory]

set -e

# Check if we're in a tmux session
if [ -z "$TMUX" ]; then
  echo "Error: Not in a tmux session" >&2
  exit 1
fi

# Check arguments
if [ $# -lt 2 ]; then
  echo "Usage: $(basename "$0") <window-name> <command> [working-directory]" >&2
  exit 1
fi

WINDOW_NAME="$1"
COMMAND="$2"
WORK_DIR="${3:-$HOME}"

# Check if window exists
if tmux list-windows -F '#{window_name}' | grep -q "^${WINDOW_NAME}$"; then
  # Window exists, switch to it
  tmux select-window -t "${WINDOW_NAME}"
else
  # Window doesn't exist, create it with the command in the given directory
  tmux new-window -n "${WINDOW_NAME}" -c "${WORK_DIR}" "${COMMAND}"
fi
