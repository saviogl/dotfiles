[user]
	email = saviogl@gmail.com
	name = Savio Lucena
[core]
	editor = vim
[pull]
	ff = only
[push]
	default = upstream
[alias]
	aa = add -A .
	aacm = !git add -A . && git commit -m
	amend = commit --amend -m
	br = branch
	brD = branch -D
	brd = branch -d
	cleanall = clean -fdx # this is dangerous, so it's intentionally long to type
	cm = commit -m
	co = checkout
	cob = checkout -b
	coo = !git fetch && git checkout
	cp = cherry-pick
	dev = !git checkout dev && git pull origin dev
	f = "!git ls-files | grep -i"
	gr = grep -Ii
	la = "!git config -l | grep alias | cut -c 7-"
	ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
	ls = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
	master = !git checkout master && git pull origin
	merged = branch --merged
	plb = "!git branch -vv | grep 'origin/.*: gone]' | awk '{print $1}' | xargs git branch -d"
	plo = pull origin
	plod = pull origin dev
	ploh = pull origin HEAD
	plom = pull origin master
	plos = pull origin staging
	po = push origin
	pod = push origin dev
	pogm = !git push origin gh-pages && git checkout master && git pull origin master && git rebase gh-pages && git push origin master && git checkout gh-pages
	poh = push origin HEAD
	pom = push origin master
	pomg = !git push origin master && git checkout gh-pages && git pull origin gh-pages && git rebase master && git push origin gh-pages && git checkout master
	pos = push origin staging
	puo = "!git push origin -u $(git symbolic-ref --short HEAD)"
	rpo = remote prune origin
	st = status
	staging = !git checkout staging && git pull origin staging
	unstage = reset --soft HEAD^
	update-submodules = submodule update --init --recursive
	upgrade-submodules = submodule update --init --remote